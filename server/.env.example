PORT=3001

# Optional: comma-separated allowed web origins (default: reflect browser Origin). Use * for dev only.
# CORS_ORIGIN=http://localhost:8081,https://app.example.com

# Optional: persistence for reports, blocks, bans (docker-compose: redis://127.0.0.1:6379)
# REDIS_URL=redis://localhost:6379

# Admin dashboard + API (set a long random value in production)
# ADMIN_TOKEN=

# App Review login (required for Apple demo account flow)
# REVIEW_DEMO_USERNAME=
# REVIEW_DEMO_PASSWORD=
# REVIEW_DEMO_USER_ID=glyph-apple-review
